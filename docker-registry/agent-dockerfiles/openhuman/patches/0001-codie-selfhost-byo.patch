 // ── Internal helpers ──────────────────────────────────────────────────────────
 
+/// Codie self-host patch: true when the container is configured with a direct
+/// BYO OpenAI-compatible endpoint (`inference_url`+`api_key`, and the URL is
+/// not the OpenHuman hosted backend). In that mode all inference bypasses the
+/// OpenHuman login gate and talks straight to the user's endpoint.
+fn codie_selfhost_byo_active(config: &Config) -> bool {
+    let url = config.inference_url.as_deref().map(str::trim).unwrap_or("");
+    let key = config.api_key.as_deref().map(str::trim).unwrap_or("");
+    !url.is_empty() && !key.is_empty() && !looks_like_openhuman_backend(url)
+}
+
+/// Codie self-host patch: build the BYO OpenAI-compatible provider straight
+/// from `inference_url`/`api_key`/`default_model`. No session required.
+fn make_codie_selfhost_byo(config: &Config) -> anyhow::Result<(Box<dyn Provider>, String)> {
+    let url = config.inference_url.as_deref().map(str::trim).unwrap_or("");
+    let key = config.api_key.as_deref().map(str::trim).unwrap_or("");
+    if url.is_empty() || key.is_empty() {
+        anyhow::bail!(
+            "[chat-factory] codie self-host BYO selected but inference_url/api_key are empty"
+        );
+    }
+    let model = config
+        .default_model
+        .clone()
+        .filter(|m| !m.trim().is_empty())
+        .unwrap_or_else(|| "gpt-4o".to_string());
+    log::info!(
+        "[providers][chat-factory] codie self-host BYO -> {} (model={})",
+        url,
+        model
+    );
+    let provider = OpenAiCompatibleProvider::new_no_responses_fallback(
+        "codie_selfhost",
+        url,
+        Some(key),
+        CompatAuthStyle::Bearer,
+    );
+    Ok((Box::new(provider), model))
+}
