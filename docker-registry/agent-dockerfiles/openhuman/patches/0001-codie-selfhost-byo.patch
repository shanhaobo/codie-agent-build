+// ── Codie self-host BYO patch ────────────────────────────────────────────
+// Codie ships openhuman-core headless with no OpenHuman account. When the
+// container is configured with a direct BYO endpoint (inference_url+api_key),
+// every workload role must route to that endpoint regardless of per-role
+// config, and the build must NOT depend on an OpenHuman session.
+
+#[test]
+fn codie_selfhost_byo_overrides_every_role() {
+    let mut config = Config::default();
+    config.inference_url = Some("https://api.deepseek.com".to_string());
+    config.api_key = Some("sk-test".to_string());
+    config.default_model = Some("deepseek-chat".to_string());
+    // Even with a per-role provider pointing elsewhere, BYO wins.
+    config.chat_provider = Some("openhuman".to_string());
+
+    for role in ["chat", "reasoning", "agentic", "coding", "memory"] {
+        assert_eq!(
+            provider_for_role(role, &config),
+            CODIE_SELFHOST_BYO,
+            "role {role} must route to the self-host BYO endpoint"
+        );
+    }
+    let (_, model) =
+        create_chat_provider_from_string("chat", CODIE_SELFHOST_BYO, &config).expect("build");
+    assert_eq!(model, "deepseek-chat");
+}
+
+#[test]
+fn codie_selfhost_byo_inactive_without_key() {
+    let mut config = Config::default();
+    config.inference_url = Some("https://api.deepseek.com".to_string());
+    // No api_key → not self-host BYO; falls through to normal resolution.
+    assert_ne!(provider_for_role("chat", &config), CODIE_SELFHOST_BYO);
+}
+
+#[test]
+fn codie_selfhost_byo_inactive_for_openhuman_url() {
+    let mut config = Config::default();
+    config.inference_url = Some("https://api.openhuman.ai/v1".to_string());
+    config.api_key = Some("sk-test".to_string());
+    // An OpenHuman backend URL is the hosted path, not a BYO endpoint.
+    assert_ne!(provider_for_role("chat", &config), CODIE_SELFHOST_BYO);
+}
